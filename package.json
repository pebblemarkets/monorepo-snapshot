{
  "name": "pebble-monorepo",
  "private": true,
  "scripts": {
    "dev:db": "docker compose -f infra/docker/compose.db.yaml up -d",
    "dev:db:down": "docker compose -f infra/docker/compose.db.yaml down",
    "daml:build": "cd contracts && dpm build --all",
    "daml:studio": "cd contracts && dpm studio",
    "daml:sandbox": "tools/scripts/daml-sandbox.sh",
    "dev:web": "pnpm -C apps/web dev",
    "dev:assets": "cargo run -p pebble-assets",
    "dev:api": "cargo run -p pebble-api",
    "dev:clearing": "cargo run -p pebble-clearing",
    "dev:indexer": "cargo run -p pebble-indexer",
    "dev:treasury": "cargo run -p pebble-treasury",
    "test:m2-offledger": "tools/scripts/test-m2-offledger.sh",
    "test:m3-catchup": "tools/scripts/test-m3-catchup.sh",
    "test:m3-e2e": "tools/scripts/test-m3-e2e.sh",
    "test:m3-offledger": "tools/scripts/test-m3-offledger.sh",
    "test:m5-load": "tools/scripts/test-m5-load.sh",
    "verify:m3-replay": "tools/scripts/verify-m3-replay.sh",
    "bootstrap:m5-tmux": "tools/scripts/bootstrap-m5-tmux.sh",
    "demo:seeded:tmux": "exec tools/scripts/demo-mode-seeded-tmux.sh",
    "demo:clean:tmux": "exec tools/scripts/demo-mode-clean-tmux.sh",
    "demo:clean:tmux:release": "exec tools/scripts/demo-mode-clean-tmux-release.sh",
    "demo:seeded:nontmux": "tools/scripts/demo-mode-seeded-nontmux.sh",
    "demo:clean:nontmux": "tools/scripts/demo-mode-clean-nontmux.sh",
    "demo:live:setup": "python3 tools/scripts/demo_live_setup.py",
    "demo:live:trade": "python3 tools/scripts/demo_live_trade.py",
    "demo:live": "python3 tools/scripts/demo_live_setup.py && python3 tools/scripts/demo_live_trade.py",
    "demo:live:stress:setup": "python3 tools/scripts/demo_live_stress_setup.py",
    "demo:live:stress:setup:release": "python3 tools/scripts/demo_live_stress_setup.py --rust-release",
    "demo:live:stress:trade": "python3 tools/scripts/demo_live_stress_trade.py",
    "demo:live:stress:trade:release": "python3 tools/scripts/demo_live_stress_trade.py",
    "demo:live:stress:trade:placement": "python3 tools/scripts/demo_live_stress_trade.py --profile placement-focused",
    "demo:live:stress": "python3 tools/scripts/demo_live_stress_setup.py && python3 tools/scripts/demo_live_stress_trade.py",
    "demo:mock:setup:markets": "python3 tools/scripts/demo_mock_setup_markets.py",
    "demo:mock:setup:users": "python3 tools/scripts/demo_mock_setup_users.py",
    "demo:mock:trade:random": "python3 tools/scripts/demo_mock_trade_random.py",
    "demo:mock:trade:arb": "python3 tools/scripts/demo_mock_trade_arb.py",
    "demo:stop": "tools/scripts/demo-mode-stop.sh",
    "verify:m5:snapshot": "tools/scripts/verify-m5-runbook.sh snapshot",
    "verify:m5:snapshot:live": "tools/scripts/verify-m5-runbook.sh snapshot-live",
    "verify:m5:load": "tools/scripts/verify-m5-runbook.sh load",
    "verify:m5:all": "tools/scripts/verify-m5-runbook.sh all",
    "bootstrap:m4-tmux": "tools/scripts/bootstrap-m4-tmux.sh",
    "verify:m4:snapshot": "tools/scripts/verify-m4-runbook.sh snapshot",
    "verify:m4:reconcile": "tools/scripts/verify-m4-runbook.sh reconcile",
    "verify:m4:all": "tools/scripts/verify-m4-runbook.sh all"
  }
}
