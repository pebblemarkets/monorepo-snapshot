# ------------------------------
# Core infra
# ------------------------------
PEBBLE_DB_URL=postgres://pebble:pebble@127.0.0.1:5432/pebble
PEBBLE_REDIS_URL=redis://127.0.0.1:6379

# ------------------------------
# Canton ledger endpoints + auth
# ------------------------------
PEBBLE_CANTON_LEDGER_API_HOST=127.0.0.1
PEBBLE_CANTON_LEDGER_API_PORT=6865
PEBBLE_CANTON_JSON_API_URL=http://127.0.0.1:7575
# Optional gRPC auth token (JWT). If it does not start with "Bearer ", it will be prefixed.
PEBBLE_CANTON_AUTH_TOKEN=
# Dev-only JSON API JWT helper
PEBBLE_CANTON_JWT=

# ------------------------------
# Party allocation (filled by sandbox allocator)
# ------------------------------
# Use full allocated party IDs, e.g. PebbleCommittee::1220...
PEBBLE_COMMITTEE_PARTY=
PEBBLE_INDEXER_PARTY=
PEBBLE_INSTRUMENT_ADMIN_PARTY=
# Optional allocation hints consumed by tools/scripts/canton-allocate-parties.mjs
PEBBLE_COMMITTEE_PARTY_HINT=PebbleCommittee
PEBBLE_INDEXER_PARTY_HINT=PebbleIndexer
PEBBLE_INSTRUMENT_ADMIN_PARTY_HINT=WizardcatInstrumentAdmin
PEBBLE_INDEXER_SAME_AS_COMMITTEE=1

# ------------------------------
# Daml sandbox helpers
# ------------------------------
PEBBLE_JSON_API_PORT=7575
# Optional explicit DAR path for tools/scripts/daml-sandbox.sh
PEBBLE_DAR=

# ------------------------------
# API server
# ------------------------------
PEBBLE_API_ADDR=127.0.0.1:3030
PEBBLE_API_DB_MAX_CONNECTIONS=40
PEBBLE_LEDGER_USER_ID=pebble-api
# M3 user auth keys (key:account_id pairs, comma-separated)
# Example: PEBBLE_API_KEYS=dev-key-1:acc-m2-1,dev-key-2:acc-m2-2
PEBBLE_API_KEYS=
# Admin/ops API keys (comma-separated)
# Example: PEBBLE_ADMIN_KEYS=ops-key-1,ops-key-2
PEBBLE_ADMIN_KEYS=
PEBBLE_TRADING_ENGINE_VERSION=m3-dev-v1
# Shared advisory lock namespace for account-level serialization (API/treasury/clearing).
PEBBLE_ACCOUNT_LOCK_NAMESPACE=11
# Disable explicit withdrawal request lifecycle states/events.
PEBBLE_WITHDRAWAL_REQUEST_STATE_DISABLED=0
# Accept ineligible withdrawals at create-time (legacy behavior).
PEBBLE_WITHDRAWAL_ACCEPT_INELIGIBLE_AT_CREATE=0
# Disable idempotent create-intent + reservation submission saga.
PEBBLE_WITHDRAWAL_SUBMISSION_SAGA_DISABLED=0
# Exclude withdrawal reservations from order-admission available balance.
PEBBLE_ORDER_AVAILABLE_EXCLUDES_WITHDRAWAL_RESERVES=0
# Guardrail for future unified account writer lane rollout.
PEBBLE_ACCOUNT_WRITER_ENABLE=0
# Guardrail gate for policy-driven active-account withdrawals (disable switch).
PEBBLE_ACTIVE_WITHDRAWALS_DISABLED=0
PEBBLE_API_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
PEBBLE_API_RATE_LIMIT_ENABLED=1
PEBBLE_API_RATE_LIMIT_WINDOW_SECONDS=60
PEBBLE_API_RATE_LIMIT_MAX_REQUESTS=120
PEBBLE_API_DISCLOSURE_TEMPLATE_ALLOWLIST=Pebble.Reference:TokenConfig,Pebble.Reference:FeeSchedule,Pebble.Reference:OracleConfig
PEBBLE_ASSETS_DATA_DIR=./data/assets
PEBBLE_ASSETS_PUBLIC_BASE_URL=http://127.0.0.1:3060/assets
PEBBLE_ASSETS_MAX_UPLOAD_BYTES=8388608

# ------------------------------
# Indexer
# ------------------------------
PEBBLE_INDEXER_AUTO_RESET=1
PEBBLE_INDEXER_SUBMISSION_PATH=

# ------------------------------
# Assets service
# ------------------------------
PEBBLE_ASSETS_ADDR=127.0.0.1:3060
PEBBLE_ASSETS_DEFAULT_QUALITY=70
PEBBLE_ASSETS_MAX_WIDTH=4096
PEBBLE_ASSETS_CACHE_MAX_ENTRIES=512

# ------------------------------
# Treasury service
# ------------------------------
PEBBLE_TREASURY_ADDR=127.0.0.1:3040
PEBBLE_TREASURY_LEDGER_USER_ID=pebble-treasury
PEBBLE_TREASURY_SUBMISSION_PATH=
PEBBLE_TREASURY_ENABLE_MOCK_REGISTRY=1
PEBBLE_TREASURY_MOCK_REGISTRY_POLL_MS=500
PEBBLE_TREASURY_CLAIM_POLL_MS=500
PEBBLE_TREASURY_DEPOSIT_ACCEPT_POLL_MS=500
PEBBLE_TREASURY_DEPOSIT_RECONCILE_POLL_MS=1000
PEBBLE_TREASURY_WITHDRAWAL_PROCESS_POLL_MS=1000
PEBBLE_TREASURY_WITHDRAWAL_RECONCILE_POLL_MS=1000
PEBBLE_TREASURY_WITHDRAWAL_CANCEL_POLL_MS=2000
PEBBLE_TREASURY_WITHDRAWAL_LOCK_EXPIRES_SECONDS=3600
PEBBLE_TREASURY_WITHDRAWAL_LOCK_RECLAIM_POLL_MS=1000
PEBBLE_TREASURY_LOCK_EXPIRY_SKEW_SECONDS=5
PEBBLE_TREASURY_CONSOLIDATION_POLL_MS=15000
PEBBLE_TREASURY_MONITOR_POLL_MS=5000
PEBBLE_TREASURY_ALERT_TREC_TGT_SECONDS=120
PEBBLE_TREASURY_ALERT_INDEXER_LAG_SECONDS=30
PEBBLE_TREASURY_ALERT_DRIFT_COVERAGE_ABS_MINOR_DEFAULT=0
PEBBLE_TREASURY_ALERT_DRIFT_COVERAGE_ABS_MINOR_BY_INSTRUMENT=
PEBBLE_TREASURY_ALERT_DRIFT_MIN_LIQUIDITY_HEADROOM_MINOR_DEFAULT=0
PEBBLE_TREASURY_ALERT_DRIFT_MIN_LIQUIDITY_HEADROOM_MINOR_BY_INSTRUMENT=

# ------------------------------
# Clearing service
# ------------------------------
PEBBLE_CLEARING_ADDR=127.0.0.1:3050
PEBBLE_CLEARING_LEDGER_USER_ID=pebble-clearing
PEBBLE_CLEARING_POLL_MS=60000
PEBBLE_CLEARING_ENABLE_APPLY=0
PEBBLE_CLEARING_ENGINE_VERSION=m3-dev-v1
PEBBLE_CLEARING_APPLY_DELAY_MS=0
PEBBLE_CLEARING_MAX_APPLIES_PER_TICK=0

# ------------------------------
# Instrument config / caps / fee policy
# ------------------------------
# Source of truth is on-ledger TokenConfig + FeeSchedule templates, projected by the indexer.
# There are no off-ledger env overrides for instrument caps or fee policy.
